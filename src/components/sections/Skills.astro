---
const facts = [
  { icon: '📍', label: 'Based in', value: 'Ostrava, Czechia' },
  { icon: '💻', label: 'Coding for', value: '5+ years, full stack' },
  { icon: '🎓', label: 'Studied', value: 'Computer Science' },
  { icon: '🏸', label: 'Off-keyboard', value: 'Badminton, football, tennis' },
];
---

<section id="about">
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
    <div class="lg:col-span-3 flex flex-col gap-6">
      <h2
        class="text-4xl md:text-5xl font-extrabold font-rethink tracking-tight text-[var(--gray-100)]"
        data-reveal-blur
      >
        Hello! <span class="wave-emoji inline-block">👋</span>
      </h2>

      <div class="flex flex-col gap-5 text-base md:text-lg leading-relaxed text-[var(--gray-300)]">
        <p data-reveal style="--reveal-delay: 120ms">
          I'm <span class="font-semibold text-[var(--gray-100)]">Jan</span> — a developer based in
          <span class="bg-gradient-to-r from-[#7611a6] via-[#c561f6] to-[#6366f1] text-transparent bg-clip-text font-semibold">Ostrava</span>
          who likes turning ideas into working products. I have a CS background and 5+ years of professional experience across the stack.
        </p>
        <p data-reveal style="--reveal-delay: 240ms">
          Most of my work in the last few years has been on a document management and e-signing platform — I started on the Node.js backend, watched it migrate to Kotlin with Micronaut, and along the way picked up Docker, AWS, and Terraform.
        </p>
        <p data-reveal style="--reveal-delay: 360ms">
          Outside of code, I keep sharp through sports — badminton is my main thing, with football and tennis on the side. Movement is non-negotiable.
        </p>
      </div>
    </div>

    <aside class="lg:col-span-2 flex flex-col gap-1 lg:mt-2">
      {facts.map((fact, i) => (
        <div
          class="fact-row group relative flex items-center gap-4 py-3 pl-5"
          data-reveal-pop
          style={`--reveal-delay: ${600 + i * 100}ms`}
        >
          <span class="text-lg leading-none">
            {fact.icon}
          </span>
          <div class="flex items-baseline gap-x-3 gap-y-0.5 flex-1 min-w-0 flex-wrap">
            <span class="text-[0.68rem] uppercase tracking-[0.14em] text-[var(--gray-400)] font-medium">
              {fact.label}
            </span>
            <span class="text-sm md:text-base text-[var(--gray-100)] font-medium">
              {fact.value}
            </span>
          </div>
        </div>
      ))}
    </aside>
  </div>
</section>

<style>
  [data-reveal-blur],
  [data-reveal],
  [data-reveal-pop] {
    opacity: 0;
    will-change: opacity, transform, filter;
  }

  [data-reveal-blur] {
    transform: translateY(10px);
    filter: blur(8px);
    transition:
      opacity 0.7s ease,
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.7s ease;
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal] {
    transform: translateY(20px);
    transition:
      opacity 0.6s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal-pop] {
    transform: scale(0.94) translateY(8px);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: var(--reveal-delay, 0ms);
  }

  [data-reveal-blur].is-visible,
  [data-reveal].is-visible,
  [data-reveal-pop].is-visible {
    opacity: 1;
    transform: translateY(0) scale(1);
    filter: blur(0);
  }

  .fact-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.625rem;
    bottom: 0.625rem;
    width: 2px;
    background: rgba(197, 97, 246, 0.22);
    border-radius: 1px;
    transition: background 0.35s ease;
  }

  .fact-row:hover::before {
    background: rgba(197, 97, 246, 0.9);
  }

  .wave-emoji {
    transform-origin: 70% 70%;
    animation: wave 4s ease-in-out infinite;
  }

  @keyframes wave {
    0%   { transform: rotate(0deg); }
    5%   { transform: rotate(14deg); }
    10%  { transform: rotate(-8deg); }
    15%  { transform: rotate(14deg); }
    20%  { transform: rotate(-4deg); }
    25%  { transform: rotate(10deg); }
    30%  { transform: rotate(0deg); }
    100% { transform: rotate(0deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal-blur],
    [data-reveal],
    [data-reveal-pop] {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }

    .wave-emoji {
      animation: none;
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
  );

  document
    .querySelectorAll('[data-reveal-blur], [data-reveal], [data-reveal-pop]')
    .forEach((el) => observer.observe(el));
</script>
