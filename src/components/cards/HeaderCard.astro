---
import Icon from "../ui/Icon.astro";
import { iconPaths } from '../ui/IconPaths';
interface Props {
  icon: keyof typeof iconPaths;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div
  class="group relative w-full max-w-[25rem] p-7 md:p-8 rounded-2xl overflow-hidden text-left
         border border-white/[0.08]
         bg-gradient-to-b from-[#1a1f3d]/70 to-[#0d1224]/70
         backdrop-blur-sm
         shadow-[0_10px_40px_-15px_rgba(0,0,0,0.6)]
         transition-[transform,border-color,box-shadow] duration-500 ease-out
         hover:-translate-y-1.5
         hover:border-[#c561f6]/30
         hover:shadow-[0_20px_50px_-15px_rgba(197,97,246,0.25)]"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"
    style="background: radial-gradient(520px circle at 50% 0%, rgba(197,97,246,0.10), transparent 45%);"
  >
  </div>

  <div class="relative flex flex-col items-start">
    <div
      class="flex items-center justify-center w-12 h-12 mb-6 rounded-xl
             bg-[#c561f6]/10 border border-[#c561f6]/20
             transition-colors duration-300
             group-hover:bg-[#c561f6]/15 group-hover:border-[#c561f6]/40"
    >
      <Icon
        icon={icon}
        size="1.4em"
        class="text-[#c561f6]"
      />
    </div>
    <h3 class="text-left text-[1.35rem] font-semibold mb-3 tracking-tight text-white">
      {title}
    </h3>
    <p class="text-left text-base leading-relaxed text-gray-400/90">
      {description}
    </p>
  </div>
</div>
