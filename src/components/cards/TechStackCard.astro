---
interface Props {
  title: string;
  img: string;
  featured?: boolean;
}

const { title, img, featured = false } = Astro.props;
---

<li class:list={['tech-card', { 'tech-card-featured': featured }]}>
  <div class="tech-card-icon">
    <img
      src={img}
      alt=""
      aria-hidden="true"
      decoding="async"
      loading="lazy"
    />
  </div>
  <span class="tech-card-name">{title}</span>
</li>
