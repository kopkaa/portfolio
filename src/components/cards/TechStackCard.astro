---
interface Props {
  title: string;
  img: string;
  featured?: boolean;
}

const { title, img, featured = false } = Astro.props;
---

<li class:list={['tech-pill', { 'tech-pill-featured': featured }]}>
  <img
    class="tech-pill-icon"
    src={img}
    alt=""
    aria-hidden="true"
    decoding="async"
    loading="lazy"
  />
  <span class="tech-pill-name">{title}</span>
</li>
