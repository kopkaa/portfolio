---
interface Props {
  href: string;
  title: string;
  img: string;
  padding?: boolean;
}

const { href, title, img, padding } = Astro.props;
---

<a
  href={href}
  class="project-card group relative w-full rounded-2xl overflow-hidden transition-all duration-300 hover:scale-105 card-box cursor-pointer"
  aria-label={`View ${title} project`}
>
  <div
    class={`flex items-center justify-center h-full w-full bg-center bg-no-repeat ${padding ? 'bg-[length:80%]' : 'bg-cover'}`}
    style={`background-image: url('${img}')`}
  />

  {/* Hover-reveal overlay: gradient scrim + "View project" CTA + company name, confirming what a click leads to */}
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 flex flex-col gap-1 p-4 bg-gradient-to-t from-black/80 via-black/40 to-transparent opacity-0 translate-y-2 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 motion-reduce:transition-none motion-reduce:translate-y-0"
  >
    <span class="flex items-center gap-1.5 text-sm font-medium uppercase tracking-wide text-white/80">
      View project
      <svg
        class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1 motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <line x1="5" y1="12" x2="19" y2="12" />
        <polyline points="12 5 19 12 12 19" />
      </svg>
    </span>
    <span class="text-white font-medium leading-tight">{title}</span>
  </div>

  <div class="absolute inset-0 border border-gray-800 rounded-2xl opacity-20 group-hover:opacity-40 transition-opacity duration-300" />
</a>
