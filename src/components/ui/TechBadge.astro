---
import { Icon } from "astro-icon/components";
import { resolveTechIcon } from "../../lib/techIcons";

interface Props {
  tag: string;
}

const { tag } = Astro.props;
const info = resolveTechIcon(tag);
const label = info?.label ?? tag;
const color = info?.color ?? "var(--gray-400)";
---

<span
  class="tech-badge"
  style={`--tech-color: ${color};`}
  aria-label={label}
>
  {info?.icon && <Icon name={info.icon} class="tech-badge__icon" aria-hidden="true" />}
  <span class="tech-badge__label">{label}</span>
</span>

<style>
  .tech-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999rem;
    font-size: var(--text-sm);
    font-weight: 500;
    line-height: 1.25;
    white-space: nowrap;
    color: var(--gray-0);
    background-color: color-mix(in srgb, var(--tech-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--tech-color) 35%, transparent);
    transition:
      background-color var(--theme-transition),
      border-color var(--theme-transition),
      transform var(--theme-transition);
  }

  .tech-badge:hover {
    background-color: color-mix(in srgb, var(--tech-color) 20%, transparent);
    border-color: color-mix(in srgb, var(--tech-color) 55%, transparent);
    transform: translateY(-1px);
  }

  .tech-badge__icon {
    width: 1rem;
    height: 1rem;
    color: var(--tech-color);
    flex-shrink: 0;
  }

  .tech-badge__label {
    letter-spacing: 0.01em;
  }

  @media (min-width: 50em) {
    .tech-badge {
      font-size: var(--text-base);
      padding: 0.35rem 0.9rem;
      gap: 0.5rem;
    }

    .tech-badge__icon {
      width: 1.15rem;
      height: 1.15rem;
    }
  }
</style>
