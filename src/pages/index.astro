---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import Grid from '../components/ui/Grid.astro';
import HeaderCard from '../components/cards/HeaderCard.astro';
import Skills from '../components/sections/Skills.astro';
import TechStackCard from '../components/cards/TechStackCard.astro';
import ProjectCard from '../components/cards/ProjectCard.astro';

const stack = await getCollection('stack');
const projects = await getCollection('projects');
---

<BaseLayout>
  <div class="flex flex-col gap-28 md:gap-40">
    <div class="wrapper flex flex-col md:min-h-0 min-h-[calc(100vh-7rem)]">
      <header class="hero flex flex-col justify-center items-center text-center mt-28 md:mt-36">
        <div class="flex flex-col gap-5 max-w-3xl">
          <div class="h-[3.5rem] md:h-[5rem] flex items-center justify-center relative">
            <h1
              id="rotating-text"
              class="text-4xl md:text-6xl font-extrabold font-rethink tracking-tight leading-none bg-gradient-to-r from-[#7611a6] via-[#c561f6] to-[#6366f1] inline-block text-transparent bg-clip-text will-change-[transform,opacity,filter] transition-[opacity,transform,filter] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]"
            ></h1>
          </div>
          <p class="text-base md:text-xl text-[var(--gray-300)] leading-relaxed max-w-2xl mx-auto opacity-0 animate-pop-in delay-500">
            Hi! I'm a full-stack developer who likes to craft products with great user experiences.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-6 mt-14 md:mt-20 w-full max-w-6xl place-items-stretch">
          <div class="opacity-0 animate-fade-in-up delay-100 flex justify-center">
            <HeaderCard
              icon="gear"
              title="Backend & APIs"
              description="I design and develop backend services, REST APIs, and integrate third-party services using primarily Node.js ecosystem."
            />
          </div>
          <div class="opacity-0 animate-fade-in-up delay-300 flex justify-center">
            <HeaderCard
              icon="code"
              title="Frontend development"
              description="I transform designs into responsive and accessible web applications using Tailwind, Vue.js, and Nuxt.js."
            />
          </div>
          <div class="opacity-0 animate-fade-in-up delay-500 flex justify-center">
            <HeaderCard
              icon="rocket-launch"
              title="Cloud"
              description="I have experience deploying applications with Docker, working with AWS services, and managing infrastructure using Terraform."
            />
          </div>
        </div>
      </header>
    </div>
    <div class="wrapper">
      <Skills />
    </div>

    <main class="wrapper flex flex-col gap-24 lg:gap-48 pt-4 md:pt-0 pb-8 md:pb-0">
      <!-- 
        <div class="cta self-end">
          <CallToAction href="/assets/cv.pdf" download>
            Download my cv
            <Icon icon="download" size="1.4em" />
          </CallToAction>
        </div>
      </section> -->

      <section class="section with-background bg-variant md:pt-0 py-28" id="stack">
        <header class="section-header flex flex-col gap-2 lg:gap-4">
          <h2 class="text-2xl">Tech stack</h2>
          <p>There is list of my favorite technologies I enjoy work with.</p>
        </header>

        <div class="gallery">
          <Grid variant="small">
            {stack.map((s) => (
              <TechStackCard title={s.data.title} img={s.data.img} />
            ))}
          </Grid>
        </div>
      </section>

      <section class="section with-background bg-variant md:pt-0 py-28" id="references">
        <header class="section-header flex flex-col gap-2 lg:gap-4">
          <h2 class="text-2xl">Projects and references</h2>
          <p>Here are some projects I did or I have been a part of</p>
        </header>

        <div class="gallery pb-8">
          <Grid variant="stack">
            {projects.map((project) => (
              <ProjectCard
                href={`/projects/${project.id}`}
                title={project.data.title}
                img={project.data.img}
                padding={project.data.padding}
              />
            ))}
          </Grid>
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<script>
  const titles = [
    "Web developer.",
    "Full-stack developer.",
    "Backend developer.",
    "Frontend developer."
  ];

  let currentIndex = 0;
  const textElement = document.getElementById('rotating-text');

  function rotateText() {
    if (!textElement) return;

    textElement.style.opacity = '0';
    textElement.style.transform = 'translateY(-8px)';
    textElement.style.filter = 'blur(6px)';

    setTimeout(() => {
      currentIndex = (currentIndex + 1) % titles.length;
      textElement.textContent = titles[currentIndex];
      textElement.style.transform = 'translateY(8px)';
      textElement.style.filter = 'blur(6px)';

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          textElement.style.opacity = '1';
          textElement.style.transform = 'translateY(0)';
          textElement.style.filter = 'blur(0)';
        });
      });
    }, 450);
  }

  if (textElement) {
    textElement.textContent = titles[currentIndex];
    textElement.style.opacity = '1';
    textElement.style.filter = 'blur(0)';

    setTimeout(() => {
      rotateText();
      setInterval(rotateText, 2800);
    }, 2000);
  }
</script>
