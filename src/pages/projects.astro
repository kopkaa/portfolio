---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';
import Grid from '../components/ui/Grid.astro';
import ProjectCard from '../components/cards/ProjectCard.astro';

const projects = await getCollection('projects');
---

<BaseLayout
  title="Projects — Jan Hromádka"
  description="Selected projects and references from my work as a full-stack web developer — CRM, document management and signing platforms, marketing and product sites."
>
  <div class="wrapper flex flex-col gap-14 md:gap-20 pt-32 md:pt-44 pb-24 md:pb-40">

    <header class="page-header flex flex-col gap-5 max-w-3xl">
      <h1 class="page-title">
        Projects &amp; References
      </h1>
      <p class="text-base md:text-lg leading-relaxed max-w-2xl" style="color: var(--gray-300);">
        Projects I've contributed to — CRM tools, a document signing platform, cloud microservices, marketing sites.
      </p>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-value">{projects.length}</span>
          <span class="stat-label">Projects</span>
        </div>
        <div class="divider" />
        <div class="stat">
          <span class="stat-value">6+</span>
          <span class="stat-label">Years exp.</span>
        </div>
        <div class="divider" />
        <div class="stat">
          <span class="stat-value">Full-stack</span>
          <span class="stat-label">Approach</span>
        </div>
      </div>
    </header>

    <main>
      <Grid variant="stack">
        {projects.map((project) => (
          <ProjectCard
            href={`/projects/${project.id}`}
            title={project.data.title}
            img={project.data.img}
            padding={project.data.padding}
          />
        ))}
      </Grid>
    </main>

  </div>
</BaseLayout>

<style>
  .eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-regular);
    opacity: 0.85;
  }

  .page-title {
    font-size: clamp(2.25rem, 5vw, 3.75rem);
    font-weight: 800;
    font-family: var(--font-brand);
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--gray-0);
  }

  .stats-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-top: 0.5rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--gray-0);
    line-height: 1;
  }

  .stat-label {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray-400);
  }

  .divider {
    width: 1px;
    height: 2.25rem;
    background: var(--gray-800);
    flex-shrink: 0;
  }
</style>
